# Copie este arquivo para .env somente no seu computador.
# Nunca suba o .env real para o GitHub.

DB_URL=jdbc:postgresql://localhost:5432/abrigovicentinodb
DB_USERNAME=postgres
DB_PASSWORD=troque_esta_senha

# Plataformas como Railway/Render podem fornecer DATABASE_URL em formato postgres://...
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

PORT=8080
SESSION_COOKIE_SECURE=false
SESSION_TIMEOUT=2h
UPLOAD_DIR=uploads

# Protecao contra tentativas repetidas em rotas publicas de escrita.
LOGIN_RATE_LIMIT_MAX=8
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
DONATION_RATE_LIMIT_MAX=6
DONATION_RATE_LIMIT_WINDOW_SECONDS=3600

# Em producao com HTTPS:
# SESSION_COOKIE_SECURE=true
#
# No Railway, use um volume persistente para uploads.
# Exemplo de mount path do volume: /data
# UPLOAD_DIR=/data/uploads
